# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# MkDocs output
site/

# Kotlin
.kotlin/

# Kotlin/JS & Kotlin/Wasm yarn lockfile — regenerated per host by the `js`/`wasmJs`/`wasmWasi`
# targets on serialkompat-annotations; not part of the published artifact for this
# annotations-only module (no JS tests), so kept out of VCS to avoid a cross-host lock
# mismatch (see #115 task 1 report).
kotlin-js-store/

# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws
out/

# macOS
.DS_Store

# Editors
*.swp
*~

# Local env / secrets
local.properties
*.local
.envrc
.env
.env.*

# Credentials / signing material — never commit (defence-in-depth; CI also runs gitleaks)
*.gpg
*.pgp
secring.*
*.pem
*.p12
*.pfx
*.jks
*.keystore

# Python bytecode from the mkdocs-macros module (main.py)
__pycache__/
*.pyc

# Claude Code local, per-machine state (not committed); keep shareable project settings
.claude/*
!.claude/settings.json

# Superpowers scratch — SDD workspace and brainstorm/plan artifacts (per-machine, not committed)
.superpowers/
docs/superpowers/
