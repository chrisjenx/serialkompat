root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

[*.{kt,kts}]
indent_size = 4
ktlint_standard_no-wildcard-imports = enabled
ktlint_function_naming_ignore_when_annotated_with = Test

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[gradlew*]
indent_style = tab
